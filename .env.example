# ============================================
# NextFlow Environment Variables
# ============================================

# Clerk Authentication
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# PostgreSQL Database (Neon)
# Get from: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Gemini API
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Trigger.dev
# Get from: https://cloud.trigger.dev
TRIGGER_API_KEY=tr_dev_your_key_here
TRIGGER_API_URL=https://api.trigger.dev
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_dev_your_key_here

# Transloadit
# Get from: https://transloadit.com/accounts/
NEXT_PUBLIC_TRANSLOADIT_KEY=your_transloadit_key
TRANSLOADIT_SECRET=your_transloadit_secret
NEXT_PUBLIC_TRANSLOADIT_TEMPLATE_ID_IMAGE=your_image_template_id
NEXT_PUBLIC_TRANSLOADIT_TEMPLATE_ID_VIDEO=your_video_template_id
